{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=terrenario;Username=terrenario;Password=REPLACE_IN_SECRETS"
  },
  "Auth": {
    "Google": {
      "ClientId": "REPLACE_WITH_GOOGLE_CLIENT_ID",
      "ClientSecret": "REPLACE_IN_SECRETS"
    },
    "Jwt": {
      "Issuer": "terrenario-api",
      "Audience": "terrenario-web",
      "AccessTokenLifetimeSeconds": 900,
      "PrivateKeyPem": "REPLACE_IN_SECRETS",
      "PublicKeyPem": "REPLACE_IN_SECRETS"
    },
    "RefreshToken": {
      "LifetimeSeconds": 2592000
    }
  },
  "Cors": {
    "AllowedOrigins": ["https://app.terrenario.com"]
  }
}
