# URL base del backend API
# Puerto del perfil "http" en src/backend/Terrenario.Api/Properties/launchSettings.json
VITE_API_BASE_URL=http://localhost:5127

# Google OAuth 2.0 Client ID (obtener en Google Cloud Console)
# https://console.cloud.google.com/apis/credentials
# Debe coincidir con el valor de Auth:Google:ClientId configurado en el backend
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
